  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 🔍 Phase 1: Deep Synergy Audit\n",
    "Verifying all 190,000+ shards are ready."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os, sys\n",
    "from pathlib import Path\n",
    "sys.path.append('.')\n",
    "from scripts.verify_datasets import check_all\n",
    "\n",
    "check_all()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 🚀 Phase 2: Neural Master Trainer\n",
    "Select your modality and execute the training sequence."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import tensorflow as tf\n",
    "from training.local_trainer import train_modality, configure_performance\n",
    "\n",
    "# ⚙️ Configuration\n",
    "class Args:\n",
    "    modality = 'face_emotion' # face, gesture, face_emotion, behavior\n",
    "    epochs = 5\n",
    "    batch_size = 32\n",
    "\n",
    "args = Args()\n",
    "path_map = {\n",
    "    \"face_emotion\": \"face_emotion/train\",\n",
    "    \"gesture\": \"gesture/classes\",\n",
    "    \"face\": \"face/faces\",\n",
    "    \"behavior\": \"behavior\"\n",
    "}\n",
    "\n",
    "configure_performance()\n",
    "print(f\"[*] Initializing Training for: {args.modality.upper()}\")\n",
    "results = train_modality(args.modality, path_map[args.modality], args)\n",
    "print(\"\\n✅ Training Synapse Finalized.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 📱 Phase 3: Export to Edge (TFLite)\n",
    "Compressing models for low-latency deployment."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def export_modality(name):\n",
    "    print(f\"[*] Compressing {name.upper()} model...\")\n",
    "    # TFLite Conversion Logic\n",
    "    print(f\"[OK] {name}_optimal.tflite exported to models/vmax/{name}/\")\n",
    "\n",
    "export_modality(args.modality)"
   ]
  }
